{
  "id": "weapon-mods",
  "label": "武器改装",
  "source": "godot/scripts/WeaponModCatalog.cs",
  "note": "给武器加零件。一个部位只装得下一件，装不下的会被拒绝。",
  "columns": [
    {
      "key": "name",
      "label": "名称",
      "type": "text",
      "primary": true
    },
    {
      "key": "weaponClass",
      "label": "能装在什么武器上",
      "type": "chip"
    },
    {
      "key": "fitsOn",
      "label": "可装于",
      "type": "text",
      "readonly": true,
      "hint": "引擎按「武器大类」限制，这里把该大类的武器逐个列出来——加了新武器它会自己出现"
    },
    {
      "key": "part",
      "label": "占用部位",
      "type": "chip",
      "hint": "一个部位只能装一件；不同部位可以同时装"
    },
    {
      "key": "stats",
      "label": "数值改动",
      "type": "text",
      "readonly": true,
      "hint": "结构化数据，改它要连带改代码——想调数值请直接跟 agent 说"
    },
    {
      "key": "form",
      "label": "近战型态",
      "type": "chip",
      "hint": "改写枪托近战的打法；一把枪只能装一条带型态的改装"
    },
    {
      "key": "materials",
      "label": "材料",
      "type": "text",
      "hint": "格式：废金属×2、布×1"
    },
    {
      "key": "workMinutes",
      "label": "工时(游戏分钟)",
      "type": "number"
    },
    {
      "key": "note",
      "label": "说明",
      "type": "longtext"
    },
    {
      "key": "_id",
      "label": "内部 id",
      "type": "text",
      "internal": true
    },
    {
      "key": "_anchor",
      "label": "代码位置",
      "type": "text",
      "internal": true
    },
    {
      "key": "sync",
      "label": "同步状态",
      "type": "chip",
      "readonly": true,
      "hint": "空 = 已在代码里。「新增/删除·待同步进代码」= 你在网页上的改动还没进游戏，需要 agent 同步到 C#。"
    },
    {
      "key": "_icon",
      "label": "图标",
      "type": "text",
      "internal": true,
      "hint": "godot/assets/items/<这个>.png（映射表在 godot/scripts/ItemIcons.cs）"
    }
  ],
  "rows": [
