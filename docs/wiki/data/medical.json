{
  "id": "medical",
  "label": "医疗与草药",
  "source": "godot/scripts/Materials.cs + godot/scripts/HealthConditions.cs",
  "note": "流血和骨折靠手术（凑手术点数），感染和疾病靠吃药。草药是抗生素用光之后的退路——治得慢，但采得到。",
  "configFile": "health.json",
  "columns": [
    {
      "key": "name",
      "label": "名称",
      "type": "text",
      "primary": true
    },
    {
      "key": "use",
      "label": "用途",
      "type": "chip"
    },
    {
      "key": "treats",
      "label": "治什么",
      "type": "chip"
    },
    {
      "key": "surgeryPoints",
      "label": "手术点数",
      "type": "number",
      "configKey": "Points",
      "configRoot": "SurgerySupplies",
      "hint": "手术要凑够点数才做得成"
    },
    {
      "key": "exclusive",
      "label": "手术独占",
      "type": "bool",
      "hint": "独占的（急救包）不能和别的耗材一起用"
    },
    {
      "key": "infectionMult",
      "label": "感染几率乘子",
      "type": "mult",
      "configKey": "InfectionChanceMultiplier",
      "configRoot": "SurgerySupplies",
      "hint": "用这味手术耗材时，该处伤口感染几率要乘的倍数（1 = 不影响；草药绷带 0.75）。空 = 非手术耗材。"
    },
    {
      "key": "efficacy",
      "label": "治疗效率",
      "type": "percent",
      "configKey": "Efficacy",
      "configRoot": "Medicines",
      "hint": "抗生素 100% 是满效；草药是它的零头。"
    },
    {
      "key": "potency",
      "label": "药效基数",
      "type": "number",
      "configKey": "Potency",
      "configRoot": "Medicines",
      "hint": "这味药一次照护的病情消退基数 0..1（成药 0.6、抗生素/草药 0.5）。空 = 非药品。"
    },
    {
      "key": "worsenMult",
      "label": "恶化减缓",
      "type": "mult",
      "hint": "当天的恶化速度要乘的倍数——越小越能拖住病情。空 = 不影响恶化。"
    },
    {
      "key": "rosehipHealBonus",
      "label": "当日恢复加成(pp)",
      "type": "number",
      "readonly": true,
      "hint": "只对玫瑰果茶：喝下当日昼夜恢复效率 +这么多个百分点（加算，非乘算）。真源在 health.json 顶层 RosehipTeaHealBonusPct（全局单值，改它去 health.json，本表只读）。"
    },
    {
      "key": "weight",
      "label": "单位重量(公斤)",
      "type": "number",
      "configFile": "materials.json",
      "configScalar": true
    },
    {
      "key": "description",
      "label": "简介",
      "type": "longtext",
      "hint": "**玩家在游戏里看到的描述**。改了它，agent 会把新文案同步进代码。（有几个分区代码里还没有描述字段——你照样可以写，写了就是在告诉 agent「这里该有一个」。）"
    },
    {
      "key": "userNote",
      "label": "备注",
      "type": "note",
      "usernote": true,
      "hint": "**你的设计笔记，不进游戏**——想到什么特殊效果就写在这（比如「这把锤子应该能砸开保险箱」）。它不会被同步成游戏文案，但 agent 每次跑抽取器都会看到你新写的备注。"
    },
    {
      "key": "_id",
      "label": "内部 id",
      "type": "text",
      "internal": true
    },
    {
      "key": "_configId",
      "label": "config 键",
      "type": "text",
      "internal": true
    },
    {
      "key": "_anchor",
      "label": "代码位置",
      "type": "text",
      "internal": true
    },
    {
      "key": "sync",
      "label": "同步状态",
      "type": "chip",
      "readonly": true,
      "hint": "空 = 已在代码里。「新增/删除·待同步进代码」= 你在网页上的改动还没进游戏，需要 agent 同步到 C#。"
    },
    {
      "key": "_icon",
      "label": "图标",
      "type": "text",
      "internal": true,
      "hint": "godot/assets/items/<这个>.png（映射表在 godot/scripts/ItemIcons.cs）"
    }
  ],
