{
  "id": "armor",
  "label": "护甲服装",
  "source": "src/DeadSignal.Combat/ArmorTable.cs",
  "note": "人穿的衣服与护甲。护甲值按部位覆盖生效——没覆盖到的部位一点也不挡。「腐皮」是丧尸天生的一层，不是能穿的衣服。",
  "columns": [
    {
      "key": "name",
      "label": "名称",
      "type": "text",
      "primary": true
    },
    {
      "key": "layer",
      "label": "甲层",
      "type": "chip",
      "hint": "同一部位可叠穿：贴身 → 外套 → 护甲板"
    },
    {
      "key": "equipSlot",
      "label": "穿戴槽",
      "type": "chip",
      "readonly": true,
      "hint": "成对装备（手套/鞋）一件占一槽，两件才护全"
    },
    {
      "key": "sharpDefense",
      "label": "锐防",
      "type": "number"
    },
    {
      "key": "bluntDefense",
      "label": "钝防",
      "type": "number"
    },
    {
      "key": "weight",
      "label": "重量(公斤)",
      "type": "number"
    },
    {
      "key": "covers",
      "label": "覆盖部位",
      "type": "text",
      "hint": "多个部位用「、」隔开"
    },
    {
      "key": "description",
      "label": "说明",
      "type": "longtext"
    },
    {
      "key": "_id",
      "label": "内部 id",
      "type": "text",
      "internal": true
    },
    {
      "key": "_anchor",
      "label": "代码位置",
      "type": "text",
      "internal": true
    },
    {
      "key": "sync",
      "label": "同步状态",
      "type": "chip",
      "readonly": true,
      "hint": "空 = 已在代码里。「新增/删除·待同步进代码」= 你在网页上的改动还没进游戏，需要 agent 同步到 C#。"
    },
    {
      "key": "_icon",
      "label": "图标",
      "type": "text",
      "internal": true,
      "hint": "godot/assets/items/<这个>.png（映射表在 godot/scripts/ItemIcons.cs）"
    }
  ],
