{
  "id": "weapons",
  "label": "武器",
  "source": "src/DeadSignal.Combat/WeaponTable.cs",
  "note": "全表武器。伤害为一次攻击的随机区间；穿透削减护甲；噪音半径决定开火后多远的敌人会被引来。「天生武器」（爪击/撕咬/拳脚）是丧尸、狗和空手的攻击，不是可拾取物品。",
  "columns": [
    {
      "key": "name",
      "label": "名称",
      "type": "text",
      "primary": true
    },
    {
      "key": "kind",
      "label": "种类",
      "type": "chip",
      "readonly": true,
      "hint": "由武器自身属性推导（远程/弹药/伤害类型），不是可改字段"
    },
    {
      "key": "damageType",
      "label": "伤害类型",
      "type": "chip"
    },
    {
      "key": "damageMin",
      "label": "伤害下限",
      "type": "number"
    },
    {
      "key": "damageMax",
      "label": "伤害上限",
      "type": "number"
    },
    {
      "key": "penetration",
      "label": "穿透",
      "type": "number",
      "hint": "0~1，0.25 = 无视 25% 护甲"
    },
    {
      "key": "attackInterval",
      "label": "攻击间隔(秒)",
      "type": "number",
      "hint": "越小出手越快"
    },
    {
      "key": "burstCount",
      "label": "连发数",
      "type": "number"
    },
    {
      "key": "burstInterval",
      "label": "连发间隔(秒)",
      "type": "number"
    },
    {
      "key": "pelletCount",
      "label": "弹丸数",
      "type": "number",
      "hint": "霰弹枪一发几颗；每颗独立选部位、独立判定"
    },
    {
      "key": "ammo",
      "label": "吃什么弹药",
      "type": "chip",
      "hint": "空 = 不吃弹药"
    },
    {
      "key": "ammoPerAttack",
      "label": "每次攻击耗弹",
      "type": "number",
      "readonly": true,
      "hint": "由连发数派生"
    },
    {
      "key": "twoHanded",
      "label": "强制双手",
      "type": "bool",
      "hint": "武器本身是否必须双手持（Weapon.TwoHanded）；单手武器也可以双手握，那是运行时的握法，不是这一列"
    },
    {
      "key": "canDualWield",
      "label": "可双持",
      "type": "bool"
    },
    {
      "key": "maxRange",
      "label": "最大射程(像素)",
      "type": "number"
    },
    {
      "key": "falloffStart",
      "label": "距离衰减起点(像素)",
      "type": "number"
    },
    {
      "key": "falloffFloor",
      "label": "最远处伤害系数",
      "type": "number",
      "hint": "超过射程末端时剩几成伤害"
    },
    {
      "key": "spread",
      "label": "基础散布(度)",
      "type": "number",
      "hint": "越大越不准"
    },
    {
      "key": "noiseRadius",
      "label": "噪音半径(像素)",
      "type": "number",
      "hint": "多远内的丧尸/劫掠者会被引来"
    },
    {
      "key": "weight",
      "label": "重量(公斤)",
      "type": "number"
    },
    {
      "key": "stockMin",
      "label": "枪托近战 伤害下限",
      "type": "number"
    },
    {
      "key": "stockMax",
      "label": "枪托近战 伤害上限",
      "type": "number"
    },
    {
      "key": "stockInterval",
      "label": "枪托近战 间隔(秒)",
      "type": "number"
    },
    {
      "key": "stockPenetration",
      "label": "枪托近战 穿透",
      "type": "number"
    },
    {
      "key": "structureFactor",
      "label": "砸墙系数",
      "type": "number"
    },
    {
      "key": "description",
      "label": "说明",
      "type": "longtext"
    },
    {
      "key": "_id",
      "label": "内部 id",
      "type": "text",
      "internal": true
    },
    {
      "key": "_anchor",
      "label": "代码位置",
      "type": "text",
      "internal": true
    },
    {
      "key": "sync",
      "label": "同步状态",
      "type": "chip",
      "readonly": true,
      "hint": "空 = 已在代码里。「新增/删除·待同步进代码」= 你在网页上的改动还没进游戏，需要 agent 同步到 C#。"
    },
    {
      "key": "_icon",
      "label": "图标",
      "type": "text",
      "internal": true,
      "hint": "godot/assets/items/<这个>.png（映射表在 godot/scripts/ItemIcons.cs）"
    }
  ],
