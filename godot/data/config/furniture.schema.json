{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "家具建造数值（furniture.json）",
  "description": "家具键 → 建造材料清单 + 建造工时。键 = camp.json prop 名。简介文案(authored)不在此。",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "additionalProperties": false,
    "required": ["cost", "buildMinutes"],
    "properties": {
      "cost": {
        "type": "object",
        "description": "材料键 → 数量（材料键对齐 Materials 目录）。",
        "minProperties": 1,
        "additionalProperties": { "type": "integer", "minimum": 0 }
      },
      "buildMinutes": {
        "type": "integer",
        "minimum": 0,
        "description": "建造工时（游戏分钟）。"
      }
    }
  }
}
